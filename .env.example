# Argentor Production Configuration
# Copy to .env and fill in your values

# Server
ARGENTOR_PORT=8080
RUST_LOG=info

# LLM Providers (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional providers
TAVILY_API_KEY=
BRAVE_API_KEY=

# Monitoring (optional, enable with: docker compose --profile monitoring up)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_PASSWORD=argentor
